# VeriGuard AI - Environment Configuration
# ==========================================

# LLM Provider (Groq)
GROQ_API_KEY=your_groq_api_key_here

# Application Settings
LOG_LEVEL=INFO
LOG_FORMAT=colored  # Use 'json' for production

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Embedding Settings
EMBEDDING_MODEL_NAME=all-mpnet-base-v2
EMBEDDING_BATCH_SIZE=32

# Retrieval Settings
RETRIEVER_TOP_K=5
RETRIEVER_USE_RERANKING=true

# Verification Settings
VERIFICATION_ENABLE_CONTRADICTION_DETECTION=true
VERIFICATION_ENABLE_TEMPORAL_ANALYSIS=true
VERIFICATION_ENABLE_NUMERIC_PRECISION=true

# Cache Settings
CACHE_ENABLED=true
CACHE_BACKEND=memory  # Options: memory, disk, redis
CACHE_TTL_SECONDS=3600
